    <worksheet name='average order value'>
      <table>
        <view>
          <datasources>
            <datasource caption='orders+' name='federated.0l4tz6d051pw6219p1qsc14ryjxp' />
          </datasources>
          <datasource-dependencies datasource='federated.0l4tz6d051pw6219p1qsc14ryjxp'>
            <column caption='revenue' datatype='real' name='[Calculation_1172651369664512]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[price]*[quantity]' />
            </column>
            <column caption='average order value' datatype='real' name='[Calculation_1172651369992193]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Calculation_1172651369664512])/COUNTD([order_id])' />
            </column>
            <column caption='Name' datatype='string' name='[name]' role='dimension' type='nominal' />
            <column caption='Order Id' datatype='integer' name='[order_id]' role='dimension' type='ordinal' />
            <column caption='Price' datatype='real' name='[price]' role='measure' type='quantitative' />
            <column caption='Quantity' datatype='integer' name='[quantity]' role='measure' type='quantitative' />
            <column caption='Size' datatype='string' name='[size]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_1172651369992193]' derivation='User' name='[usr:Calculation_1172651369992193:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0l4tz6d051pw6219p1qsc14ryjxp].[Action (Name)]'>
            <groupfilter function='level-members' level='[name]' user:ui-action-filter='[Action1_0261B072393D4043B9301C652BDF75A3]' user:ui-enumeration='all' user:ui-marker='enumerate' />
          </filter>
